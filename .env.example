HF_TOKEN=
GITHUB_TOKEN=
OPENAI_API_KEY=
ML_INTERN_DEFAULT_MODEL_ID=moonshotai/Kimi-K2.6
ML_INTERN_KPIS_DISABLED=1

# Google Cloud / Vertex AI training backend
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_REGION=us-central1
GCS_BUCKET=
VERTEX_AI_STAGING_BUCKET=
VERTEX_AI_OUTPUT_DIR=

# Optional: Vertex runtime service account if jobs should run as a different SA.
VERTEX_AI_SERVICE_ACCOUNT=

# Optional production web hardening.
CORS_ALLOW_ORIGINS=
ALLOWED_HOSTS=

# Optional: override the default Vertex AI training image.
GCP_VERTEX_DEFAULT_IMAGE=us-docker.pkg.dev/deeplearning-platform-release/gcr.io/pytorch-cu124.2-4.py310

# AWS / SageMaker
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_PREFIX=liga-ml
AWS_SAGEMAKER_ROLE_ARN=
AWS_DEFAULT_INSTANCE_TYPE=ml.g5.xlarge
AWS_DEFAULT_INSTANCE_COUNT=1
AWS_DEFAULT_MAX_RUN_SECONDS=3600
AWS_OUTPUT_POLICY=aws-private
AWS_SAGEMAKER_TRAINING_IMAGE_URI=

# Optional local development only. Prefer IAM roles in production.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
